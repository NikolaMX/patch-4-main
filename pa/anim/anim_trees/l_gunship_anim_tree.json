{
  "blend_root": {
    "type": "unit_state",
    "nodes": {
      "being_built": {
        "type": "playback",
        "anim_name": "build"
      },
      "living": {
        "type": "sequence",
        "entries": [
          {
            "type": "item",
            "name": "deploy",
            "node": {
              "type": "playback",
              "anim_name": "deploy",
              "looping": false,
              "events": []
            },
            "transitions": [
              {
                "transition_forward": {
                  "func": "anim_complete",
                  "target": "idle",
                  "duration": 0.2
                },
                "transition_reverse": {
                  "func": "anim_complete",
                  "target": "idle",
                  "duration": 0.2
                }
              }
            ],
            "reset": "playback_reset"
          },
          {
            "type": "item",
            "name": "idle",
            "node": {
              "type": "playback",
              "anim_name": "idle",
              "looping": true,
              "events": []
            },
            "transitions": [
              {
                "transition_forward": {
                  "func": "is_moving_forward",
                  "target": "fly",
                  "duration": 0.2
                },
                "transition_reverse": {
                  "func": "is_moving_forward",
                  "target": "fly",
                  "duration": 0.2
                }
              }
            ],
            "reset": "playback_reset"
          },
          {
            "type": "item",
            "name": "fly",
            "node": {
              "type": "playback",
              "anim_name": "fly",
              "looping": true,
              "events": []
            },
            "transitions": [
              {
                "transition_forward": {
                  "func": "is_hovering",
                  "target": "idle",
                  "duration": 0.2
                },
                "transition_reverse": {
                  "func": "is_hovering",
                  "target": "idle",
                  "duration": 0.2
                }
              }
            ],
            "reset": "playback_reset"
          }
        ]
      },
      "dead": {
        "type": "bind_pose"
      },
      "ghost": {
        "type": "bind_pose"
      }
    }
  },
  "skeleton_controls": [
    {
      "bone": "bone_recoil",
      "recoil_dist": 0.75,
      "restore_time": 0.25,
      "type": "recoil",
      "unit_event": "fired0"
    },
    {
      "child": {
        "rotation_axis": "z",
        "rotation_bone": "bone_turret",
        "type": "procedural_aim"
      },
      "lerp_func": "not_being_built",
      "type": "fader"
    },
    {
      "child": {
        "rotation_axis": "x",
        "rotation_bone": "bone_pitch",
        "type": "procedural_aim"
      },
      "lerp_func": "not_being_built",
      "type": "fader"
    }
  ]
}